# ---------------------------------------------------------------------------
# Google Reviews (homepage "They trusted us. So can you." section)
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values below.
# These are SERVER-ONLY secrets — do NOT prefix them with NEXT_PUBLIC_.
#
# Without GOOGLE_PLACES_API_KEY, the reviews section simply does not render
# (no empty placeholder, no build error).

# Required: a Google Cloud API key with the "Places API (New)" enabled.
# https://console.cloud.google.com/  → APIs & Services → Enable "Places API (New)"
GOOGLE_PLACES_API_KEY=

# Optional but recommended: the Google Place ID for Wellness Detox of LA.
# Find it at https://developers.google.com/maps/documentation/places/web-service/place-id
# If left blank, it is resolved automatically from the business name + address.
GOOGLE_PLACE_ID=
